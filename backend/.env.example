# ─────────────────────────────────────────────────────────
# Travello Backend – Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Django Core ─────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Admin Setup (used by: python manage.py setup_admin) ─
ADMIN_EMAIL=superadmin@travello.com
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=

# ── Database ────────────────────────────────────────────
# Docker Compose auto-injects DATABASE_URL; this is for non-Docker use:
# DATABASE_URL=postgres://travello:travello_secret@localhost:5432/travello_db

# ── CORS ────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── AI / ML Services ───────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Stripe Payments (Test Mode) ────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY_PRIMARY=PKR
STRIPE_CURRENCY_FALLBACK=USD
FRONTEND_PAYMENT_SUCCESS_URL=http://localhost:3000/payment-success
FRONTEND_PAYMENT_CANCEL_URL=http://localhost:3000/payment-cancel

# ── Email (Gmail SMTP) ─────────────────────────────────
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── reCAPTCHA ───────────────────────────────────────────
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# ── Google OAuth ────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Cloudinary (Image uploads) ──────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Monitoring ──────────────────────────────────────────
SENTRY_DSN=
